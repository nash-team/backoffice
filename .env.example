# Application Environment
# Values: development, staging, production
ENVIRONMENT=development

# Database Configuration
# For local development (without Docker)
DATABASE_URL=postgresql://username:password@localhost:5432/backoffice_dev
# For Docker Compose (use asyncpg driver + service name "postgres")
# DATABASE_URL=postgresql+asyncpg://backoffice:dev_password@postgres:5432/backoffice_dev
# For testing
# DATABASE_URL=sqlite:///./test.db

# Server Configuration
# development: 127.0.0.1 (localhost only)
# production: 0.0.0.0 (all interfaces) - use with caution
HOST=127.0.0.1
PORT=8001

# Google Drive Configuration (OPTIONAL - falls back to local storage if not configured)
# If these are not set, the system will use local file storage automatically
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json

# ========================================
# GOOGLE OAUTH AUTHENTICATION
# ========================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application type)
# Add authorized redirect URI: http://localhost:8001/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Secret key for signing session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=your-session-secret-key-here

# Local File Storage Configuration (used when Google Drive is not available)
# Path where generated PDFs will be stored locally
LOCAL_STORAGE_PATH=./storage

# ========================================
# IMAGE GENERATION API KEYS
# ========================================
# Model selection is in config/generation/models.yaml (NOT here!)
# This file only contains API keys and secrets.

# OpenRouter API Key (for google/gemini-*, black-forest-labs/flux-*, etc.)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Gemini Direct API Key (optional, for direct Gemini access)
# Get your key from: https://aistudio.google.com/app/apikey
# Note: Imagen 3 not available in all countries via AI Studio
GEMINI_API_KEY=your-gemini-api-key-here

# Application Configuration
APP_NAME=Backoffice
APP_VERSION=1.0.0
DEBUG=True

# Testing Environment
TESTING=false
